# Copy this file to .env or .env.local and fill in values you want to keep server-side.
# Do not commit real API keys.

# Studio
STUDIO_PORT=5177
# JSON_CONTRACTS_DIR=./json-contracts

# Generic defaults used by the LLM API key mode UI.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_THINKING=medium
# Supported thinking levels: off, low, medium, high, xhigh, auto
# LLM_REQUEST_TIMEOUT_MS=120000
# LLM_BASE_URL=
# LLM_API_KEY=

# Major native providers
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-5

OLLAMA_API_KEY=your_ollama_cloud_api_key_here
# OLLAMA_MODEL=kimi-k2.5
# OLLAMA_THINKING=medium
# OLLAMA_BASE_URL=https://ollama.com/api
# OLLAMA_FORMAT=schema

# OpenAI-compatible providers
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# GROQ_API_KEY=your_groq_api_key_here
# TOGETHER_API_KEY=your_together_api_key_here
# FIREWORKS_API_KEY=your_fireworks_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# MISTRAL_API_KEY=your_mistral_api_key_here

# Local Ollama does not require a key.
# LLM_PROVIDER=ollama-local
# OLLAMA_BASE_URL=http://127.0.0.1:11434/api
# OLLAMA_MODEL=llama3.2
